    "build:render": "npm install --include=dev && vite build",
    "start": "node server/index.js",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "marketing:deck": "node scripts/generate-client-deck.js",
